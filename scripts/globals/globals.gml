//variável global que recebe a pontuação
global.score = 0;

//variavel que mostra a pontuação atualizada no hud
global.score_display = 0;

//variável que recebe a pontução máxima alacançada pelo player
global.max_score = 0;

//inicialize aqui para garantir que existem antes de tudo
global.frutinhas = 0;

//se o player perdeu, esperar 1 segundo para reinicia
global.losing = false;